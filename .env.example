# PrivateClaw Configuration
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env

# Application
PRIVATECLAW_APP_NAME=CatClaw
PRIVATECLAW_DATA_DIR=./data
PRIVATECLAW_LOG_LEVEL=INFO

# LLM Configuration - DeepSeek
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.7
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.deepseek.com

# Memory Configuration
MEMORY_SHORT_TERM_LIMIT=50
MEMORY_LONG_TERM_ENABLED=true
MEMORY_VECTOR_STORE=chroma
MEMORY_VECTOR_STORE_PATH=./data/chroma
MEMORY_EMBEDDING_MODEL=text-embedding-3-small

# Gateway Configuration
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=18789
GATEWAY_DEBUG=false
GATEWAY_SECRET_KEY=change-this-to-a-random-string

# Channel Configuration
CHANNEL_WEB_ENABLED=true
CHANNEL_WEB_HOST=0.0.0.0
CHANNEL_WEB_PORT=8000
CHANNEL_CLI_ENABLED=true

# Telegram (optional)
CHANNEL_TELEGRAM_ENABLED=false
CHANNEL_TELEGRAM_TOKEN=your-telegram-bot-token

# Discord (optional)
CHANNEL_DISCORD_ENABLED=false
CHANNEL_DISCORD_TOKEN=your-discord-bot-token

# Slack (optional)
CHANNEL_SLACK_ENABLED=false
CHANNEL_SLACK_TOKEN=your-slack-bot-token
CHANNEL_SLACK_APP_TOKEN=your-slack-app-token

# WeChat (optional)
CHANNEL_WECHAT_ENABLED=false

# QQ Bot (optional) - https://q.qq.com
CHANNEL_QQ_ENABLED=false
CHANNEL_QQ_BOT_ID=your-qq-app-id
CHANNEL_QQ_BOT_SECRET=your-qq-app-secret
CHANNEL_QQ_SANDBOX=true

# Feishu/Lark Bot (optional) - https://open.feishu.cn
CHANNEL_FEISHU_ENABLED=false
CHANNEL_FEISHU_APP_ID=your-feishu-app-id
CHANNEL_FEISHU_APP_SECRET=your-feishu-app-secret
CHANNEL_FEISHU_VERIFICATION_TOKEN=your-verification-token
CHANNEL_FEISHU_ENCRYPT_KEY=your-encrypt-key
